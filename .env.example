# Copy to .env and fill in before: docker compose up --build
JWT_SECRET=use-a-long-random-string-at-least-32-chars

# AES-256 file encryption key (32 bytes, base64) — required for production
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Bootstrap admin password — required for production (do not use admin123)
SUPERUSER_PASSWORD=change-me-in-production

# PostgreSQL (required for production compose)
POSTGRES_DB=texton
POSTGRES_USER=texton
POSTGRES_PASSWORD=

# Comma-separated allowed browser origins (production HTTPS URL)
TEXTON_CORS_ORIGINS=https://your-domain.com

# Groq AI (primary for document Q&A) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Google Gemini (embeddings + fallback chat)
GEMINI_API_KEY=
